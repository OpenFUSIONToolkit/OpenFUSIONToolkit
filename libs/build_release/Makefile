# fast build rule for target.
marklin_eigs/fast:
	$(MAKE) $(MAKESILENT) -f bin/CMakeFiles/marklin_eigs.dir/build.make bin/CMakeFiles/marklin_eigs.dir/build
.PHONY : marklin_eigs/fast

