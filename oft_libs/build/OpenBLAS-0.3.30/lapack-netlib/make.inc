FC          = gfortran-15
override FFLAGS      = -O2 -frecursive -fPIC -fno-tree-vectorize
FFLAGS_DRV  = -O2 -frecursive -fPIC
POPTS       = -frecursive -fPIC -pg -fno-inline
FFLAGS_NOOPT       = -O0 -frecursive -fPIC
PNOOPT      = -frecursive -fPIC -pg -fno-inline -O0
LDFLAGS     = -O2 -frecursive -fPIC -lgfortran
CC          = gcc-15
override CFLAGS      = -O2 -DMAX_STACK_ALLOC=2048 -DUSE_LOCKING -Wall -DF_INTERFACE_GFORT -fPIC -DNO_LAPACKE -DNO_AVX -DNO_AVX2 -DNO_SVE -DNO_SME -DNO_WARMUP -DMAX_CPU_NUMBER=10 -DMAX_PARALLEL_NUMBER=1 -DBUILD_SINGLE=1 -DBUILD_DOUBLE=1 -DBUILD_COMPLEX=1 -DBUILD_COMPLEX16=1 -DVERSION="0.3.30" -march=armv8.3-a -UASMNAME -UASMFNAME -UNAME -UCNAME -UCHAR_NAME -UCHAR_CNAME -DASMNAME=_ -DASMFNAME=__ -DNAME=_ -DCNAME= -DCHAR_NAME="_" -DCHAR_CNAME="" -DNO_AFFINITY -I. -DHAVE_LAPACK_CONFIG_H
AR          = ar
ARFLAGS     =  -ru
RANLIB      = ranlib
LAPACKLIB   = ../../libopenblas_vortex-r0.3.30.a
TMGLIB      = ../../../libopenblas_vortex-r0.3.30.a
BLASLIB     = ../../../libopenblas_vortex-r0.3.30.a
LAPACKELIB  = ../../../libopenblas_vortex-r0.3.30.a
LAPACKLIB_P = ../libopenblas_vortex-r0.3.30_p.a
SUFFIX      = o
PSUFFIX     = po
CEXTRALIB   = -lgfortran
TIMER       = INT_ETIME
LOADER      = gfortran-15
BUILD_DEPRECATED      = 1
BUILD_SINGLE      = 1
BUILD_DOUBLE      = 1
BUILD_COMPLEX      = 1
BUILD_COMPLEX16      = 1
LAPACKE_WITH_TMG      = 1
SHELL = /bin/sh
PLAT = _LINUX
DRVOPTS  = $(NOOPT)
#ARCHFLAGS= $(ARFLAGS) -ru
#RANLIB   = ranlib

