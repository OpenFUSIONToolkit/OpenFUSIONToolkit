[build-system]
requires = ["setuptools"]
build-backend = "setuptools.build_meta"

[project]
name = "OpenFUSIONToolkit"
authors = [
    {name = "Anson Braun"},
    {name = "Daniel Burgess"},
    {name = "Samuel Freiberger"},
    {name = "Sophia Guizzo"},
    {name = "Chris Hansen"},
    {name = "Julia Kirby"},
    {name = "John Lhota"},
    {name = "Francois Logak"},
    {name = "Oak Nelson"},
    {name = "Matthew Pharr"},
    {name = "Benjy Smith"},
    {name = "Thomas Wang"},
]
maintainers = [
  {name = "Chris Hansen", email = "christopher.hansen@columbia.edu"}
]
description = "Modeling tools for plasma and fusion research and engineering"
readme = "README.md"
requires-python = ">=3.7"
keywords = ["Fusion", "Plasma", "TokaMaker", "ThinCurr"]
license = "LGPL-3.0-only"
license-files = ["LICENSE"]
classifiers = [
    "Development Status :: 4 - Beta",
    "Programming Language :: Python :: 3",
    "Topic :: Scientific/Engineering :: Physics"
]
dependencies = [
    "numpy",
    "scipy",
    "matplotlib",
    "h5py",
    "netCDF4"
]
version = "@CMAKE_PROJECT_VERSION@@OFT_PYPI_VER_SUFFIX@"

[project.urls]
Homepage = "https://openfusiontoolkit.github.io/OpenFUSIONToolkit/"
Documentation = "https://openfusiontoolkit.github.io/OpenFUSIONToolkit/docs/index.html"
Repository = "https://github.com/openfusiontoolkit/OpenFUSIONToolkit"
Issues = "https://github.com/openfusiontoolkit/OpenFUSIONToolkit/issues"

[project.optional-dependencies]
viz = ["pyvista"]

[tool.setuptools.package-data]
OpenFUSIONToolkit = ["lib*"]