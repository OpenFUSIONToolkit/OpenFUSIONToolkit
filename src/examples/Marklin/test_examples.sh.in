#!/bin/bash

log_path=$1
ROOT_PATH=$(pwd)

run_test() {
  cd $1
  jupyter nbconvert --execute --to notebook --inplace $2 > tmp.log 2>&1
  if [ $? -ne 0 ]; then
    echo "Example Marklin/$1/$2 failed."
    echo "" >> $log_path
    echo "====== Begin Marklin/$1/$2 output ======" >> $log_path
    cat tmp.log >> $log_path
    echo "======  End Marklin/$1/$2 output  ======" >> $log_path
    echo "" >> $log_path
  else
    echo "Example Marklin/$1/$2 ran successfully."
  fi
  rm tmp.log
  cd $ROOT_PATH
}

# Cylinder cases
run_test cylinder Marklin_ex1.ipynb

# NCSX cases
run_test NCSX NCSX_vac_ex.ipynb