&runtime_options
  ppn=1
  debug=3
/

&mesh_options
  meshname='test'
  cad_type=92
  nlevels=1
  nbase=1
  grid_order=2
  fix_boundary=T
/

&native_mesh_options
  filename="circle_2d.h5"
/

&cube_options
 mesh_type=1
 ref_per=T,F,F
 ni=8,8,0
 rscale=2.0,2.0,0.0
 shift=-1.0,-1.0,0.0
/

&xmhd_options
  order=2
  n0=1E19,
  psi0=0,
  velx0=0,
  vely0=0,
  velz0=0,
  t0=1E19,
  by0=0,
  chi=1.E-6
  eta=1.E-6
  nu=1.E-9
  gamma=2.0
  D_diff=1.E-8
  dt=1.E-4
  nsteps=500
  rst_freq=10
  use_mfnk=F
  pm=T
/
